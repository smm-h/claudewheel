{
  "defaults": {
    "app": {
      "env_prefix": null,
      "config": false,
      "global_flags": [],
      "commands": {},
      "groups": {},
      "deprecated": {}
    },
    "flag": {
      "short": null,
      "default": null,
      "env": null,
      "choices": null,
      "repeatable": false,
      "unique": false,
      "env_separator": null,
      "negatable": null,
      "hidden": false
    },
    "arg": {
      "required": true,
      "variadic": false
    },
    "command": {
      "passthrough": false,
      "flags": [],
      "args": []
    },
    "group": {
      "commands": {},
      "groups": {},
      "deprecated": {}
    }
  },
  "project_id": "claudewheel",
  "name": "c",
  "version": "0.10.1",
  "help": "claudewheel - TUI launcher for Claude Code",
  "commands": {
    "health": {
      "name": "health",
      "help": "run health check and exit"
    },
    "config": {
      "name": "config",
      "help": "open config dir in editor"
    },
    "versions": {
      "name": "versions",
      "help": "list available versions and exit"
    },
    "install": {
      "name": "install",
      "help": "download and install a specific Claude Code version",
      "args": [
        {
          "name": "version",
          "help": "version to install"
        }
      ]
    },
    "uninstall": {
      "name": "uninstall",
      "help": "delete an installed Claude Code version",
      "args": [
        {
          "name": "version",
          "help": "version to uninstall"
        }
      ]
    },
    "reset-options": {
      "name": "reset-options",
      "help": "delete options.json so it regenerates from defaults"
    },
    "new-profile": {
      "name": "new-profile",
      "help": "run the profile creation wizard"
    },
    "delete-profile": {
      "name": "delete-profile",
      "help": "delete a registered profile and all associated data",
      "flags": [
        {
          "name": "force",
          "type": "bool",
          "help": "force deletion even if sessions appear active",
          "default": false,
          "negatable": true
        }
      ],
      "args": [
        {
          "name": "name",
          "help": "profile name to delete"
        }
      ]
    },
    "show": {
      "name": "show",
      "help": "print current selections and exit"
    },
    "migrate": {
      "name": "migrate",
      "help": "migrate sessions between profiles",
      "args": [
        {
          "name": "src",
          "help": "source profile"
        },
        {
          "name": "dst",
          "help": "destination profile"
        },
        {
          "name": "uuid",
          "help": "UUID substring filter",
          "required": false
        }
      ]
    },
    "stats": {
      "name": "stats",
      "help": "report shared-store stats and clean up legacy data",
      "flags": [
        {
          "name": "dry-run",
          "type": "bool",
          "help": "preview changes without writing",
          "default": false,
          "negatable": true
        }
      ]
    },
    "mv": {
      "name": "mv",
      "help": "rename a project directory and migrate session data",
      "flags": [
        {
          "name": "dry-run",
          "type": "bool",
          "help": "preview changes without writing",
          "default": false,
          "negatable": true
        },
        {
          "name": "post-hoc",
          "type": "bool",
          "help": "skip filesystem rename, migrate sessions only (directory already renamed)",
          "default": false,
          "negatable": true
        }
      ],
      "args": [
        {
          "name": "old",
          "help": "old directory path"
        },
        {
          "name": "new",
          "help": "new directory path"
        }
      ]
    },
    "deploy-hooks": {
      "name": "deploy-hooks",
      "help": "deploy hook scripts to ~/.claudewheel/scripts/",
      "flags": [
        {
          "name": "all",
          "type": "bool",
          "help": "deploy all known hook scripts",
          "default": false,
          "negatable": true
        },
        {
          "name": "force",
          "type": "bool",
          "help": "overwrite existing scripts instead of skipping",
          "default": false,
          "negatable": true
        }
      ],
      "args": [
        {
          "name": "name",
          "help": "script name to deploy",
          "required": false
        }
      ]
    },
    "launch": {
      "name": "launch",
      "help": "start the interactive TUI launcher",
      "flags": [
        {
          "name": "cont",
          "type": "bool",
          "help": "continue the most recent conversation",
          "short": "c",
          "default": false,
          "negatable": true
        },
        {
          "name": "resume",
          "type": "str",
          "help": "resume a session (ID, or empty for picker)",
          "short": "r",
          "default": "\u0000__unset__"
        },
        {
          "name": "print-prompt",
          "type": "str",
          "help": "run in non-interactive print mode with the given prompt",
          "short": "p",
          "default": "\u0000__unset__"
        },
        {
          "name": "picker",
          "type": "bool",
          "help": "open the session resume picker",
          "default": false,
          "negatable": true
        },
        {
          "name": "profile",
          "type": "str",
          "help": "preset value for the Profile segment",
          "default": ""
        },
        {
          "name": "github",
          "type": "str",
          "help": "preset value for the GH segment",
          "default": ""
        },
        {
          "name": "model",
          "type": "str",
          "help": "preset value for the Model segment",
          "default": ""
        },
        {
          "name": "directory",
          "type": "str",
          "help": "preset value for the Dir segment",
          "default": ""
        },
        {
          "name": "mcp",
          "type": "str",
          "help": "preset value for the MCP segment",
          "default": ""
        },
        {
          "name": "permissions",
          "type": "str",
          "help": "preset value for the Perms segment",
          "default": ""
        },
        {
          "name": "set",
          "type": "str",
          "help": "set a segment value (e.g. -s version=2.1.119)",
          "short": "s",
          "repeatable": true
        }
      ]
    }
  },
  "groups": {
    "permission": {
      "name": "permission",
      "help": "manage profile permissions",
      "commands": {
        "add": {
          "name": "add",
          "help": "add a permission rule",
          "flags": [
            {
              "name": "profile",
              "type": "str",
              "help": "profile name"
            },
            {
              "name": "all-profiles",
              "type": "bool",
              "help": "apply to all profiles",
              "default": false,
              "negatable": true
            }
          ],
          "args": [
            {
              "name": "category",
              "help": "permission category (allow, deny, ask)"
            },
            {
              "name": "rule",
              "help": "permission rule (e.g. Bash, Read(//home/**))"
            }
          ]
        },
        "remove": {
          "name": "remove",
          "help": "remove a permission rule",
          "flags": [
            {
              "name": "profile",
              "type": "str",
              "help": "profile name"
            },
            {
              "name": "all-profiles",
              "type": "bool",
              "help": "apply to all profiles",
              "default": false,
              "negatable": true
            }
          ],
          "args": [
            {
              "name": "category",
              "help": "permission category (allow, deny, ask)"
            },
            {
              "name": "rule",
              "help": "permission rule to remove"
            }
          ]
        },
        "list": {
          "name": "list",
          "help": "list permission rules",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices": [
                "grouped",
                "flat",
                "json"
              ]
            },
            {
              "name": "category",
              "type": "str",
              "help": "filter to a single category (allow, deny, ask)",
              "default": ""
            },
            {
              "name": "profile",
              "type": "str",
              "help": "profile name"
            },
            {
              "name": "all-profiles",
              "type": "bool",
              "help": "apply to all profiles",
              "default": false,
              "negatable": true
            }
          ]
        }
      }
    }
  }
}
