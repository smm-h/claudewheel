{
  "targets": [
    "npm",
    "pypi"
  ],
  "publish_mode": "ci",
  "push_timeout": 120,
  "env_file": "~/Projects/.env",
  "pipelines": {
    "npm": {
      "type": "npm",
      "local": false,
      "provenance": true
    },
    "pypi": {
      "type": "pypi",
      "local": false
    },
    "docs-deploy": {
      "type": "cloudflare-pages",
      "local": true
    }
  },
  "coverage_unit": "commit"
}
