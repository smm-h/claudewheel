{
  "targets": [
    "npm",
    "pypi"
  ],
  "publish_mode": "ci",
  "push_timeout": 120,
  "env_file": "~/Projects/.env",
  "pipelines": {
    "npm": {
      "type": "npm",
      "target": "npm",
      "local": false,
      "provenance": true
    },
    "pypi": {
      "type": "pypi",
      "target": "pypi",
      "local": false
    },
    "docs-deploy": {
      "type": "cloudflare-pages",
      "target": null,
      "local": true
    }
  },
  "coverage_unit": "commit",
  "external_checks": [
    {
      "name": "mypy-strict",
      "command": "uv run mypy claudewheel",
      "tag": "preflight"
    }
  ]
}
